{
  "name": "Weekly Report",
  "description": "Strategic, insightful, analysis-heavy email for weekly intelligence report",
  "vibe": "Strategic, insightful, analysis-heavy",
  "colors": {
    "bg_primary": "#fafaf8",
    "bg_section": "#ffffff",
    "text_primary": "#2c2416",
    "text_secondary": "#5c4033",
    "accent": "#5c4033",
    "highlight": "#d4a574",
    "border": "#e8dcc8"
  },
  "fonts": {
    "headings": "Playfair Display, serif",
    "body": "Lora, serif",
    "mono": "JetBrains Mono, monospace",
    "google_fonts_url": "https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Lora:wght@400;600&family=JetBrains+Mono&display=swap"
  },
  "typography": {
    "headline_size": "clamp(28px, 6vw, 36px)",
    "body_size": "clamp(14px, 1.5vw, 16px)",
    "mono_size": "clamp(12px, 1vw, 13px)"
  },
  "layout": {
    "max_width": "600px",
    "section_padding": "32px",
    "line_height": "1.8"
  },
  "structure": [
    "Hero section (week number + date range)",
    "Theme cards (impact rating)",
    "Impact map (chip→ai→app flow)",
    "Q&A section",
    "Watch list"
  ],
  "constraints": {
    "max_sections": 6,
    "max_images": 3,
    "max_cta_buttons": 2,
    "max_image_height": "400px"
  },
  "dark_mode": {
    "bg_primary": "#1a1714",
    "bg_section": "#2d2620",
    "text_primary": "#f0ebe5",
    "text_secondary": "#c9b5a0"
  }
}
