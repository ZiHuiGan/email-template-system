{
  "name": "Dark Minimal",
  "description": "Navy blue background with orange accent — inspired by SlidesCarinval design language",
  "category": "dark",
  "colors": {
    "bg_primary": "#0F1A38",
    "bg_section": "#1a2744",
    "text_primary": "#ffffff",
