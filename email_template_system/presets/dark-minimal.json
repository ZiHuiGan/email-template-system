    "border": "#2a3a5c"
  },
  "fonts": {
    "headings": "Poppins, system-ui, -apple-system, sans-serif",
    "body": "Poppins, system-ui, -apple-system, sans-serif",
    "mono": "JetBrains Mono, Consolas, monospace",
