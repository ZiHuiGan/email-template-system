{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Email Style Preset Schema",
  "description": "Schema for visual style presets — defines design language, not content type",
  "type": "object",
  "required": ["name", "description", "category", "colors", "fonts"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable preset name (e.g., 'Corporate Blue')"
    },
    "description": {
      "type": "string",
      "description": "Short description of the visual style"
    },
    "category": {
      "type": "string",
      "enum": ["professional", "dark", "editorial", "creative"],
      "description": "Style category for discovery"
    },
    "colors": {
      "type": "object",
      "required": ["bg_primary", "text_primary", "accent"],
      "properties": {
        "bg_primary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "bg_section": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "text_primary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "text_secondary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "accent": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "highlight": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "border": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
      }
    },
    "fonts": {
      "type": "object",
      "required": ["headings", "body"],
      "properties": {
        "headings": { "type": "string" },
        "body": { "type": "string" },
        "mono": { "type": "string" },
        "google_fonts_url": { "type": "string" }
      }
    },
    "typography": {
      "type": "object",
      "properties": {
        "headline_size": { "type": "string" },
        "body_size": { "type": "string" },
        "mono_size": { "type": "string" }
      }
    },
    "layout": {
      "type": "object",
      "properties": {
        "max_width": { "type": "string" },
        "section_padding": { "type": "string" },
        "line_height": { "type": "string" }
      }
    },
    "design": {
      "type": "object",
      "description": "Signature visual elements",
      "properties": {
        "border_radius": { "type": "string" },
        "shadow": { "type": "string" },
        "header_style": { "type": "string", "enum": ["filled", "minimal", "gradient"] }
      }
    },
    "dark_mode": {
      "type": "object",
      "properties": {
        "bg_primary": { "type": "string" },
        "bg_section": { "type": "string" },
        "text_primary": { "type": "string" },
        "text_secondary": { "type": "string" }
      }
    }
  }
}
