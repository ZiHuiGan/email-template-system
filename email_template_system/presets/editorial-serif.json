    "accent": "#b8452a",
    "highlight": "#b8452a",
    "border": "#8a7f66"
  },
  "fonts": {
    "headings": "Georgia, 'Iowan Old Style', 'Times New Roman', serif",
    "body": "Georgia, 'Iowan Old Style', 'Times New Roman', serif",
    "mono": "ui-monospace, 'SF Mono', Consolas, monospace",
    "google_fonts_url": ""
  },
  "typography": {
