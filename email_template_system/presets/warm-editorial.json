{
  "name": "Warm Editorial",
  "description": "Magazine-style with serif typography and warm cream tones",
  "category": "editorial",
  "colors": {
    "bg_primary": "#faf6f1",
    "bg_section": "#ffffff",
    "text_primary": "#2c2c2c",
    "text_secondary": "#6b6b6b",
    "accent": "#c0392b",
    "highlight": "#d4a373",
    "border": "#e8e0d8"
  },
  "fonts": {
    "headings": "Crimson Text, Georgia, serif",
    "body": "Source Sans Pro, system-ui, sans-serif",
    "mono": "Source Code Pro, Consolas, monospace",
    "google_fonts_url": "https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,700;1,400&family=Source+Sans+Pro:wght@400;600&family=Source+Code+Pro&display=swap"
  },
  "typography": {
    "headline_size": "clamp(24px, 5vw, 30px)",
    "body_size": "clamp(15px, 1.6vw, 17px)",
    "mono_size": "clamp(13px, 1.1vw, 14px)"
  },
  "layout": {
    "max_width": "600px",
    "section_padding": "28px",
    "line_height": "1.7"
  },
  "design": {
    "border_radius": "2px",
    "shadow": "0 1px 2px rgba(0,0,0,0.06)",
    "header_style": "minimal"
  },
  "dark_mode": {
    "bg_primary": "#1c1917",
    "bg_section": "#292524",
    "text_primary": "#e7e5e4",
    "text_secondary": "#a8a29e"
  }
}
